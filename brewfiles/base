##
# Homebrew Bundle
# https://github.com/Homebrew/homebrew-bundle
#
# `brew leaves` shows installed formulae that are not dependencies of another.
# `brew bundle dump -f > Brewfile` generates a complete Brewfile.
# `brew bundle cleanup` removes formulae not listed in the Brewfile.
##

## Shells
brew 'bash'    # GNU Bourne-Again SHell
brew 'nushell' # Modern shell for the GitHub era
brew 'zsh'     # UNIX shell

## Shell tools
brew 'atuin'      # Improved shell history for bash, zsh, fish, and nushell
brew 'carapace'   # Multi-shell multi-command argument completer
brew 'sheldon'    # Cross-shell plugin manager
brew 'shellcheck' # Static analysis tool for shell scripts
brew 'starship'   # Cross-shell prompt
brew 'zellij'     # Terminal workspace and multiplexer
brew 'zoxide'     # Shell extension to navigate the filesystem faster

## Core utils (newer than macOS-bundled versions)
brew 'curl'  # Get a file from an HTTP, HTTPS or FTP server
brew 'grep'  # GNU grep, egrep and fgrep
brew 'rsync' # Fast incremental file transfer utility

## Git
brew 'git'     # Distributed version control system
brew 'git-lfs' # Git large file storage
brew 'gh'      # GitHub command-line tool

## Files and search
brew 'bat'     # cat with syntax highlighting and Git integration
brew 'eza'     # Modern replacement for ls
brew 'fd'      # Simple, fast alternative to find
brew 'fzf'     # General-purpose command-line fuzzy finder
brew 'ripgrep' # Recursively search directories for a regex pattern
brew 'tlrc'    # Official tldr client written in Rust
brew 'trash'   # Move files to the Trash via the CLI
brew 'tree'    # Display directories as trees
brew 'yazi'    # Blazing fast terminal file manager based on async I/O

## HTTP clients
brew 'httpie' # User-friendly cURL replacement
brew 'wget'   # Non-interactive HTTP/HTTPS/FTP file retrieval

## Containers
brew 'podman' # Tool for managing OCI containers and pods

## Image processing
brew 'graphicsmagick' # Image processing tools

## macOS defaults
# TODO: Move to mise (github:dsully/macos-defaults) after Apple Silicon migration
#       — no x86_64 prebuilt binary, Homebrew compiles from source on Intel
tap 'dsully/tap'
brew 'macos-defaults' # Manage macOS defaults declaratively via YAML

## macOS utilities
brew 'duti'              # Select default apps for documents and URL schemes
brew 'stow'              # Organize files using symlinks

## Runtime and task management
brew 'mise' # Dev tools, environment, and task manager

## Third-party taps
tap 'tobi/try https://github.com/tobi/try'
brew 'try' # Ephemeral workspace manager
