##
# Homebrew Cask — macOS GUI applications
# https://github.com/Homebrew/homebrew-bundle
# https://github.com/Homebrew/homebrew-cask
##

cask_args appdir: '/Applications'

## AI, LLM, and Machine Learning
cask 'claude'           # Anthropic's official Claude AI desktop app
cask 'claude-code'      # Anthropic's terminal-based AI coding assistant
cask 'cursor-cli'       # Command-line agent for Cursor
cask 'lm-studio'        # Discover, download, and run local LLMs
cask 'opencode-desktop' # OpenCode AI coding agent desktop client
cask 'repo-prompt'      # Prompt generation for automated context pipelines

## Backup
cask 'arq'                 # encrypted online backup utility
cask 'carbon-copy-cloner'  # hard disk backup and cloning utility
cask 'chronosync'          # synchronisation and backup tool

## Code editors and terminal emulators
cask 'cmux'               # terminal designed for working with AI coding agents
cask 'coderunner'         # lightweight, multi-language, programming editor
cask 'cursor'             # integrated dev environment for coding with AI agents
cask 'ghostty'            # terminal emulator with GPU acceleration
cask 'sublime-text'       # text editor
cask 'visual-studio-code' # Microsoft Visual Studio Code
cask 'zed'                # Multiplayer code editor

## Collaboration
cask 'basecamp'       # all-in-one toolkit for working remotely
cask 'linear-linear'  # manage software development and track bugs
cask 'miro'           # collaborative whiteboard platform

## Design
cask 'figma'  # collaborative design software
cask 'sketch' # digital design application

## Development
cask 'dash'            # API documentation browser and code snippet manager
cask 'kaleidoscope'    # diff tool for code and images
cask 'ngrok'           # secure introspectable tunnels to localhost
cask 'orbstack'        # replacement for Docker Desktop
cask 'podman-desktop'  # browse, manage, inspect containers and images
cask 'tower'           # Git client and GUI

## Documents and notes
cask 'atuin-desktop' # runbook editor for terminal workflows
cask 'bike'          # record and process ideas
cask 'taskpaper'     # plain text to-do lists

## File management
cask 'betterzip' # file archive utility
cask 'forklift'  # file transfer application and SFTP client
cask 'renamer'   # file renaming utility
cask 'transmit'  # file transfer application

## QuickLook plugins
cask 'suspicious-package' # inspect installer packages
cask 'syntax-highlight'   # syntax highlighting for source code, JSON, CSV, patch files

## Security and privacy
cask '1password@7'        # password manager v7
cask 'nordvpn'            # NordVPN client
cask 'proton-drive'       # client for Proton Drive
cask 'proton-mail'        # client for Proton Mail and Proton Calendar
cask 'proton-mail-bridge' # bridges Proton Mail with Apple Mail
cask 'proton-pass'        # desktop client for Proton Pass
cask 'protonvpn'          # client for Proton VPN

## System utilities
cask 'appcleaner' # thoroughly uninstall unwanted apps
cask 'cocktail'   # macOS maintenance tools
cask 'daisydisk'  # disk usage analyzer

## Window management
cask 'nikitabobko/tap/aerospace' # AeroSpace tiling window manager for macOS
