#!/bin/sh
#
# Display outdated Homebrew formulae, Mac App Store apps, mise tools,
# and global npm packages in the Notification Center on macOS.
#
# Requires: alerter (available via Homebrew)
#
# Homebrew: /opt/homebrew/bin (Apple Silicon), /usr/local/bin (Intel)
BREW_PREFIX=/opt/homebrew
[ -d "$BREW_PREFIX" ] || BREW_PREFIX=/usr/local
PATH=$BREW_PREFIX/bin:$PATH

# alerter is required for all notifications
command -v alerter > /dev/null 2>&1 || exit 0

# Icons installed by tasks/install/launch-agents.sh
ICON_DIR="$BREW_PREFIX/share/package-updates-notifier"

sleep 10 # give the network a chance to connect on wake from sleep

# Send a macOS alert notification if there is output to display.
# Uses --group to replace previous notifications in the same group,
# preventing duplicates across runs. Backgrounded because alerter
# blocks until the user dismisses or --timeout expires.
# --appIcon uses a private macOS API; alerter handles fallback gracefully.
# @see https://github.com/vjeantet/alerter
notify_if_outdated() {
  title="$1"
  subtitle="$2"
  group="$3"
  icon="$4"
  output="$5"

  if [ -n "$output" ]; then
    icon_flag=""
    [ -f "$ICON_DIR/$icon" ] && icon_flag="--appIcon $ICON_DIR/$icon"
    alerter \
      --title "$title" \
      --subtitle "$subtitle" \
      --message "$output" \
      --group "$group" \
      --timeout 30 \
      $icon_flag > /dev/null 2>&1 &
  fi
}

# Homebrew formulae
if command -v brew > /dev/null 2>&1; then
  brew update > /dev/null 2>&1
  homebrew_outdated=$(brew outdated | sort)
  notify_if_outdated "Homebrew" "updates available" \
    "homebrew-updates" "homebrew.png" "$homebrew_outdated"
  brew cleanup > /dev/null 2>&1
fi

# Mac App Store applications
if command -v mas > /dev/null 2>&1; then
  mas_outdated=$(mas outdated 2>/dev/null | sed 's/^[0-9]* //; s/ ([^)]*)//')
  notify_if_outdated "Mac App Store" "updates available" \
    "mas-updates" "appstore.png" "$mas_outdated"
fi

# Mise tools
if command -v mise > /dev/null 2>&1; then
  mise_outdated=$(mise outdated 2>/dev/null | awk 'NR!=1 {print $1}')
  notify_if_outdated "Mise" "tool updates available" \
    "mise-updates" "mise.png" "$mise_outdated"
fi

# NPM packages
if command -v npm > /dev/null 2>&1; then
  npm_outdated=$(npm --global outdated 2>/dev/null | awk '{if (NR!=1) {print $1}}')
  notify_if_outdated "NPM" "global package updates available" \
    "npm-updates" "npm.png" "$npm_outdated"
fi

# Wait for all backgrounded alerter processes to finish
wait
