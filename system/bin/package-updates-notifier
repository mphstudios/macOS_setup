#!/bin/sh
#
# Display outdated Homebrew formulae, Mac App Store apps, mise tools,
# and global npm packages in the Notification Center on macOS.
#
# Requires: alerter or terminal-notifier (available via Homebrew)
#

# Prefer alerter (alert-style, stays on screen) and use terminal-notifier
# on Intel where alerter has no x86_64 binary.
# Use --help to verify the binary actually runs on this architecture.
NOTIFIER=""
if alerter --help > /dev/null 2>&1; then
  NOTIFIER="alerter"
elif command -v terminal-notifier > /dev/null 2>&1; then
  NOTIFIER="terminal-notifier"
else
  exit 0
fi

# Notification icons installed by tasks/install/launch-agents.sh
ICONS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/package-updates-notifier/icons"

sleep 10 # give the network a chance to connect on wake from sleep

# Send a macOS notification if there is output to display.
# Uses --group/-group to replace previous notifications in the same group,
# preventing duplicates across runs.
#
# alerter: blocks until dismissed or --timeout expires, so backgrounded.
#          Supports --appIcon (private macOS API) for per-source icons.
# terminal-notifier: returns immediately (banner-style, auto-dismisses).
#
# @see https://github.com/vjeantet/alerter
# @see https://github.com/julienXX/terminal-notifier
notification() {
  title="$1"
  subtitle="$2"
  group="$3"
  icon="$4"
  message="$5"

  if [ -n "$message" ]; then
    if [ "$NOTIFIER" = "alerter" ]; then
      alerter \
        --message "$message" \
        --group "$group" \
        --title "$title" \
        --subtitle "$subtitle" \
        --sender com.apple.Terminal \
        --actions "Dismiss" \
        --app-icon "$ICONS_DIR/$icon" \
        --timeout 30 \
        > /dev/null 2>&1 &
    else
      terminal-notifier \
        -message "$message" \
        -group "$group" \
        -title "$title" \
        -subtitle "$subtitle" \
        -sender com.apple.Terminal \
        > /dev/null 2>&1
    fi
  fi
}

# Homebrew formulae
if command -v brew > /dev/null 2>&1; then
  brew update > /dev/null 2>&1
  outdated=$(brew outdated | sort)
  notification "Homebrew" "updates available" \
    "homebrew-updates" "homebrew.png" "$outdated"
  brew cleanup > /dev/null 2>&1
fi

# Mac App Store applications
if command -v mas > /dev/null 2>&1; then
  outdated=$(mas outdated 2>/dev/null | sed 's/^[0-9]* //; s/ ([^)]*)//')
  notification "Mac App Store" "updates available" \
    "mas-updates" "appstore.png" "$outdated"
fi

# Mise tools
if command -v mise > /dev/null 2>&1; then
  outdated=$(mise outdated 2>/dev/null | awk 'NR!=1 {print $1}')
  notification "Mise" "tool updates available" \
    "mise-updates" "mise.png" "$outdated"
fi

# npm packages
if command -v npm > /dev/null 2>&1; then
  outdated=$(npm --global outdated 2>/dev/null | awk '{if (NR!=1) {print $1}}')
  notification "npm" "global package updates available" \
    "npm-updates" "npm.png" "$outdated"
fi

# Wait for all backgrounded alerter processes to finish
wait
