<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>local.default-shell</string>
    <key>Description</key>
    <string>Set the default shell to nushell</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/launchctl</string>
      <string>setenv</string>
      <string>SHELL</string>
      <string>${BREW_PREFIX}/bin/nu</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
  </dict>
</plist>
